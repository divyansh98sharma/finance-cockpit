generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Institution {
  KOTAK
  ICICI
  CRED
  OTHER
}

enum SourceProvider {
  GMAIL
  UPLOAD
  MANUAL
  SYSTEM
}

enum SourceConnectionStatus {
  ACTIVE
  PAUSED
  ERROR
  DISCONNECTED
}

enum ArtifactKind {
  PDF
  CSV
  EXCEL
  IMAGE
  SCREENSHOT
  EMAIL
  TEXT
  OTHER
}

enum ProcessingStatus {
  PENDING
  RUNNING
  COMPLETED
  NEEDS_REVIEW
  FAILED
}

enum IngestJobType {
  BACKFILL
  INCREMENTAL
  MANUAL_UPLOAD
  REPROCESS
}

enum ReviewRecordType {
  TRANSACTION
  TRANSFER
  OBLIGATION
  INCOME
  INVESTMENT
  ACCOUNT
  CARD
}

enum ReviewStatus {
  OPEN
  ACCEPTED
  EDITED
  REJECTED
}

enum AccountType {
  SAVINGS
  CURRENT
  WALLET
  CASH
  OTHER
}

enum CardNetwork {
  VISA
  MASTERCARD
  RUPAY
  AMEX
  OTHER
}

enum TransactionDirection {
  DEBIT
  CREDIT
}

enum TransactionSourceType {
  BANK_STATEMENT
  CARD_STATEMENT
  EMAIL_ALERT
  CRED_RECORD
  MANUAL
  OTHER
}

enum LedgerRecordStatus {
  CONFIRMED
  NEEDS_REVIEW
  IGNORED
}

enum ObligationType {
  CREDIT_CARD_DUE
  BILL
  EMI
  RENT
  SUBSCRIPTION
  OTHER
}

enum ObligationStatus {
  UPCOMING
  PAID
  OVERDUE
  WAIVED
  CANCELLED
}

enum InvestmentAssetType {
  MUTUAL_FUND
  EQUITY
  ETF
  FIXED_DEPOSIT
  PPF
  NPS
  OTHER
}

model SourceConnection {
  id              String                 @id @default(cuid())
  provider        SourceProvider
  name            String
  status          SourceConnectionStatus @default(ACTIVE)
  institution     Institution?
  accountEmail    String?
  externalId      String?
  metadata        Json?
  lastSyncedAt    DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  sourceArtifacts SourceArtifact[]
  ingestJobs      IngestJob[]
  accounts        Account[]
  cards           Card[]

  @@index([provider, status])
  @@index([institution])
}

model SourceArtifact {
  id                   String              @id @default(cuid())
  sourceConnectionId   String?
  kind                 ArtifactKind
  originalName         String
  mimeType             String?
  sizeBytes            BigInt?
  sha256               String              @unique
  storagePath          String
  statementPeriodStart DateTime?
  statementPeriodEnd   DateTime?
  receivedAt           DateTime?
  textExtractStatus    ProcessingStatus    @default(PENDING)
  parseStatus          ProcessingStatus    @default(PENDING)
  parserVersion        String?
  metadata             Json?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  sourceConnection     SourceConnection?   @relation(fields: [sourceConnectionId], references: [id], onDelete: SetNull)
  ingestJobs           IngestJob[]
  reviewItems          ReviewItem[]
  transactions         Transaction[]
  transfers            Transfer[]
  obligations          Obligation[]
  incomeEvents         IncomeEvent[]
  investmentHoldings   InvestmentHolding[]

  @@index([kind, parseStatus])
  @@index([sourceConnectionId])
  @@index([statementPeriodStart, statementPeriodEnd])
}

model IngestJob {
  id                 String            @id @default(cuid())
  type               IngestJobType
  status             ProcessingStatus  @default(PENDING)
  sourceConnectionId String?
  sourceArtifactId   String?
  startedAt          DateTime?
  completedAt        DateTime?
  errorMessage       String?
  stats              Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  sourceConnection   SourceConnection? @relation(fields: [sourceConnectionId], references: [id], onDelete: SetNull)
  sourceArtifact     SourceArtifact?   @relation(fields: [sourceArtifactId], references: [id], onDelete: SetNull)
  reviewItems        ReviewItem[]

  @@index([status, createdAt])
  @@index([sourceConnectionId])
  @@index([sourceArtifactId])
}

model ReviewItem {
  id               String           @id @default(cuid())
  recordType       ReviewRecordType
  status           ReviewStatus     @default(OPEN)
  confidence       Decimal?         @db.Decimal(5, 4)
  summary          String
  proposedData     Json
  resolvedData     Json?
  resolutionNote   String?
  sourceArtifactId String?
  ingestJobId      String?
  resolvedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  sourceArtifact   SourceArtifact?  @relation(fields: [sourceArtifactId], references: [id], onDelete: SetNull)
  ingestJob        IngestJob?       @relation(fields: [ingestJobId], references: [id], onDelete: SetNull)
  transactions     Transaction[]
  transfers        Transfer[]
  obligations      Obligation[]
  incomeEvents     IncomeEvent[]

  @@index([status, recordType])
  @@index([sourceArtifactId])
  @@index([ingestJobId])
}

model Account {
  id                 String            @id @default(cuid())
  sourceConnectionId String?
  institution        Institution
  name               String
  type               AccountType
  currency           String            @default("INR")
  accountLast4       String?
  currentBalance     Decimal?          @db.Decimal(18, 2)
  balanceAsOf        DateTime?
  isActive           Boolean           @default(true)
  metadata           Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  sourceConnection   SourceConnection? @relation(fields: [sourceConnectionId], references: [id], onDelete: SetNull)
  cards              Card[]
  transactions       Transaction[]
  outgoingTransfers  Transfer[]        @relation("TransferFromAccount")
  incomingTransfers  Transfer[]        @relation("TransferToAccount")
  obligations        Obligation[]
  incomeEvents       IncomeEvent[]

  @@index([institution, type])
  @@index([sourceConnectionId])
}

model Card {
  id                 String            @id @default(cuid())
  sourceConnectionId String?
  linkedAccountId    String?
  institution        Institution
  name               String
  network            CardNetwork?
  last4              String?
  currency           String            @default("INR")
  creditLimit        Decimal?          @db.Decimal(18, 2)
  currentBalance     Decimal?          @db.Decimal(18, 2)
  statementDate      Int?
  dueDay             Int?
  annualRate         Decimal?          @db.Decimal(7, 4)
  minimumDue         Decimal?          @db.Decimal(18, 2)
  isActive           Boolean           @default(true)
  metadata           Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  sourceConnection   SourceConnection? @relation(fields: [sourceConnectionId], references: [id], onDelete: SetNull)
  linkedAccount      Account?          @relation(fields: [linkedAccountId], references: [id], onDelete: SetNull)
  transactions       Transaction[]
  outgoingTransfers  Transfer[]        @relation("TransferFromCard")
  obligations        Obligation[]

  @@index([institution])
  @@index([sourceConnectionId])
  @@index([linkedAccountId])
}

model Transaction {
  id               String                @id @default(cuid())
  accountId        String?
  cardId           String?
  sourceArtifactId String?
  reviewItemId     String?
  occurredAt       DateTime
  postedAt         DateTime?
  description      String
  merchant         String?
  amount           Decimal               @db.Decimal(18, 2)
  direction        TransactionDirection
  currency         String                @default("INR")
  category         String?
  sourceType       TransactionSourceType
  externalId       String?
  dedupeKey        String?
  confidence       Decimal?              @db.Decimal(5, 4)
  status           LedgerRecordStatus    @default(NEEDS_REVIEW)
  raw              Json?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  account          Account?              @relation(fields: [accountId], references: [id], onDelete: SetNull)
  card             Card?                 @relation(fields: [cardId], references: [id], onDelete: SetNull)
  sourceArtifact   SourceArtifact?       @relation(fields: [sourceArtifactId], references: [id], onDelete: SetNull)
  reviewItem       ReviewItem?           @relation(fields: [reviewItemId], references: [id], onDelete: SetNull)

  @@unique([dedupeKey])
  @@index([occurredAt])
  @@index([accountId, occurredAt])
  @@index([cardId, occurredAt])
  @@index([status])
  @@index([sourceArtifactId])
}

model Transfer {
  id               String             @id @default(cuid())
  fromAccountId    String?
  toAccountId      String?
  fromCardId       String?
  sourceArtifactId String?
  reviewItemId     String?
  occurredAt       DateTime
  amount           Decimal            @db.Decimal(18, 2)
  currency         String             @default("INR")
  description      String?
  dedupeKey        String?
  confidence       Decimal?           @db.Decimal(5, 4)
  status           LedgerRecordStatus @default(NEEDS_REVIEW)
  raw              Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  fromAccount      Account?           @relation("TransferFromAccount", fields: [fromAccountId], references: [id], onDelete: SetNull)
  toAccount        Account?           @relation("TransferToAccount", fields: [toAccountId], references: [id], onDelete: SetNull)
  fromCard         Card?              @relation("TransferFromCard", fields: [fromCardId], references: [id], onDelete: SetNull)
  sourceArtifact   SourceArtifact?    @relation(fields: [sourceArtifactId], references: [id], onDelete: SetNull)
  reviewItem       ReviewItem?        @relation(fields: [reviewItemId], references: [id], onDelete: SetNull)

  @@unique([dedupeKey])
  @@index([occurredAt])
  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([fromCardId])
  @@index([status])
}

model Obligation {
  id               String           @id @default(cuid())
  type             ObligationType
  status           ObligationStatus @default(UPCOMING)
  accountId        String?
  cardId           String?
  sourceArtifactId String?
  reviewItemId     String?
  payee            String
  amount           Decimal          @db.Decimal(18, 2)
  currency         String           @default("INR")
  dueDate          DateTime
  paidAt           DateTime?
  confidence       Decimal?         @db.Decimal(5, 4)
  evidence         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  account          Account?         @relation(fields: [accountId], references: [id], onDelete: SetNull)
  card             Card?            @relation(fields: [cardId], references: [id], onDelete: SetNull)
  sourceArtifact   SourceArtifact?  @relation(fields: [sourceArtifactId], references: [id], onDelete: SetNull)
  reviewItem       ReviewItem?      @relation(fields: [reviewItemId], references: [id], onDelete: SetNull)

  @@index([status, dueDate])
  @@index([accountId])
  @@index([cardId])
  @@index([sourceArtifactId])
}

model IncomeEvent {
  id               String             @id @default(cuid())
  accountId        String?
  sourceArtifactId String?
  reviewItemId     String?
  receivedAt       DateTime
  payer            String?
  amount           Decimal            @db.Decimal(18, 2)
  currency         String             @default("INR")
  category         String             @default("salary")
  confidence       Decimal?           @db.Decimal(5, 4)
  status           LedgerRecordStatus @default(NEEDS_REVIEW)
  raw              Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  account          Account?           @relation(fields: [accountId], references: [id], onDelete: SetNull)
  sourceArtifact   SourceArtifact?    @relation(fields: [sourceArtifactId], references: [id], onDelete: SetNull)
  reviewItem       ReviewItem?        @relation(fields: [reviewItemId], references: [id], onDelete: SetNull)

  @@index([receivedAt])
  @@index([accountId])
  @@index([status])
}

model InvestmentHolding {
  id               String              @id @default(cuid())
  sourceArtifactId String?
  institution      Institution?
  name             String
  assetType        InvestmentAssetType
  symbol           String?
  units            Decimal?            @db.Decimal(24, 8)
  averageCost      Decimal?            @db.Decimal(18, 2)
  currentValue     Decimal?            @db.Decimal(18, 2)
  currency         String              @default("INR")
  asOf             DateTime
  metadata         Json?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  sourceArtifact   SourceArtifact?     @relation(fields: [sourceArtifactId], references: [id], onDelete: SetNull)

  @@index([assetType])
  @@index([institution])
  @@index([asOf])
  @@index([sourceArtifactId])
}
